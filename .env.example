# Application
APP_URL=http://localhost:3000
APP_URLS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
NODE_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Security — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
ENCRYPTION_KEY=<32-character-random-string>
SESSION_SECRET=<long-random-string-at-least-32-chars>

# SoundCloud OAuth2 — get from https://developers.soundcloud.com
SOUNDCLOUD_CLIENT_ID=<your-soundcloud-client-id>
SOUNDCLOUD_CLIENT_SECRET=<your-soundcloud-client-secret>
SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Admin — comma-separated SoundCloud user IDs
ADMIN_IDS=<your-soundcloud-user-id>
