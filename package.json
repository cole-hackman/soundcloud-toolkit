{
  "name": "soundcloud-tool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
    "dev:frontend": "cd frontend-UI && npm run dev",
    "dev:server": "NODE_ENV=development node server/index.js",
    "build": "npm install && npm run build:frontend && npm run prisma:generate",
    "build:frontend": "cd frontend-UI && npm install && npm run build",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init --skip-seed"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@vercel/analytics": "^1.3.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",

    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.17.3",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "node-fetch": "^3.3.2",
    "prisma": "^5.7.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/jest": "^29.5.8",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "typescript": "^5.5.3"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "transform": {},
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "verbose": false
  }
}
