// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  soundcloudId Int      @unique
  username    String
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tokens         Token[]
  operationLogs  OperationLog[]

  @@map("users")
}

model Token {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  encrypted String   // Encrypted access token
  refresh   String   // Encrypted refresh token
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tokens")
  @@unique([userId])
}

model OperationLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String   // 'merge' | 'from-likes' | 'bulk-unlike' | 'bulk-unfollow' | 'resolve' | 'batch-resolve' | 'proxy-download' | 'bulk-remove-reposts'
  status     String   @default("success")  // 'success' | 'split' | 'error'
  trackCount Int      @default(0)
  itemCount  Int      @default(0)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("operation_logs")
}
